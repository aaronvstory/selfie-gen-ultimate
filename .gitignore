# Scratch frame extracts from analysis (committed copies live in docs/analysis/)
analysis_frames/

# Corpus measurement outputs contain private persona identifiers
# (real folder names / SSN-format IDs). Repro: re-run
# docs/analysis/measure_sourav_*.py to regenerate locally.
docs/analysis/sourav_facetrack_results.json
docs/analysis/sourav_kinematic_results.json

# rPPG/ tool is now committed in-tree (Phase D of polish/v2.3,
# 2026-05-22). Previous policy (gitignored as confidential) is
# preserved in git history at commit ce3637f and prior.
# oldcam_reference_bundle/ stays ignored (confidential analysis bundle).
oldcam_reference_bundle/
# Permanent Kling test fixture (real generated video, ~20MB) used by
# the rPPG/oldcam test harness. Keep on disk; never track.
oldcam-testing/front_crop_nano-banana-2-edit_sim87_001_k25tStd_p4_1.mp4
# rPPG harness run outputs (injected videos, frame extracts, reports)
oldcam-testing/rppg_harness_out/
# (scoped: the bare '*-rppg.mp4' was over-broad and could hide a
# legitimate repo output anywhere; harness byproducts are covered
# by the oldcam-testing/-scoped patterns below.)
# rPPG/oldcam chain-harness byproducts dropped directly in oldcam-testing/
oldcam-testing/*-oldcam-v*.mp4
oldcam-testing/*-rppg*.mp4
oldcam-testing/*-rppg - *.mp4
# rPPG chain-harness loop intermediate (introduced when --chain gained
# the real Loop step). Same gitignored-byproduct class as above.
oldcam-testing/*_looped.mp4

# rPPG injector iterative-mode byproducts. The injector writes
# temp_iteration_N.mp4 files into its own cwd (rPPG/) and never
# cleans them up if the run crashes. PR fix/rppg-failure-visibility
# added a best_iteration_snapshot.mp4 alongside them (defensive
# snapshot of the current best) which is cleaned up at end-of-run
# but, like the temps, only when the run reaches the cleanup block.
# Iteration history JSON + TSVs land in rPPG/iteration_history/ on
# every run — useful locally for debugging but never tracked.
rPPG/temp_iteration_*.mp4
rPPG/best_iteration_snapshot.mp4
rPPG/best_iteration_snapshot_*.mp4
rPPG/iteration_history/

# Local analysis/decision artifacts (not part of the shipped app). Swept
# into a commit once by an accidental `git add -A`; ignore so it can't recur.
OLDCAM_DECISION_BRIEF.md
OLDCAM_GUIDE.md
docs/analysis/

# Friend-shared diagnostic logs (contain real file paths + email-named files = PII).
_friend_logs/
